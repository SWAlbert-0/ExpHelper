# Images
WEBAPP_BASE_IMAGE=eclipse-temurin:17-jre
FRONT_NGINX_IMAGE=nginx:1.27-alpine
FRONT_NODE_IMAGE=node:18-alpine
MONGO_IMAGE=mongo:7.0
RABBITMQ_IMAGE=rabbitmq:3.13-management
NACOS_IMAGE=nacos/nacos-server:v2.3.2

# Ports
WEBAPP_PORT=8080
FRONT_PORT=8086
MONGO_PORT=27017
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
NACOS_PORT=8848

# App credentials
APP_MONGO_DB=expHlp
APP_MONGO_USER=user
APP_MONGO_PASSWORD=123456
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=123456
RABBITMQ_USERNAME=user
RABBITMQ_PASSWORD=123456

# App runtime
AUTH_JWT_SECRET=change-me-in-dev
AUTH_JWT_EXPIRE_SECONDS=86400
ALG_CALL_CONNECT_TIMEOUT_MS=3000
ALG_CALL_READ_TIMEOUT_MS=10000
ALG_CALL_RETRY_TIMES=1
NACOS_SERVER_ADDR=nacos:8848

# Frontend build-time API (empty means same-origin; nginx proxies /api to webapp)
VUE_APP_BASE_API=

# Optional frontend build network config (only for container-build mode)
# If your network requires proxy, set reachable proxy URLs (do NOT use 127.0.0.1 unless container can reach host loopback)
FRONT_HTTP_PROXY=
FRONT_HTTPS_PROXY=
NPM_REGISTRY=https://registry.npmmirror.com

# Optional local-frontend mode
FRONTEND_DIST_PATH=../exphlp-front/dist
