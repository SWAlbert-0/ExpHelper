package fjnu.edu.messqueue.rabbitmq.consumer;

import com.example.algorithm.domain.optMethods.GA.entity.ExeResult;
import org.springframework.amqp.rabbit.annotation.RabbitHandler;
import org.springframework.amqp.rabbit.annotation.RabbitListener;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.mongodb.core.MongoTemplate;
import org.springframework.data.mongodb.core.query.Criteria;
import org.springframework.data.mongodb.core.query.Query;
import org.springframework.data.mongodb.core.query.Update;
import org.springframework.stereotype.Component;

import java.util.Map;

@Component
@RabbitListener(queues = "StopRunQueue")//监听的队列名称 StopRunQueue
public class StopRunReceiver {


    @Autowired
    private MongoTemplate mongoTemplate;
    @RabbitHandler
    public void process(Map message){


        int runNum=(Integer)message.get("runNum");
        long endTime=(long) message.get("endTime");

        //创建条件对象
        Criteria criteria = Criteria.where("_id").is(runNum);
        //创建查询对象，然后将条件对象添加到其中
        Query query = new Query(criteria);
        //创建更新对象，并设置更新的内容
        Update update = new Update().set("endTime",endTime);
        //执行更新
         mongoTemplate.upsert(query,update, ExeResult.class,"alg_run_record");
        /*System.out.println("第一个StopRunReceiver消费者收到消息  : " + message.toString());*/
    }
}
