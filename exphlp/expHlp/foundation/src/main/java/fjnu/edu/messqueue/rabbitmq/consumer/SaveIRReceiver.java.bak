package fjnu.edu.messqueue.rabbitmq.consumer;

import com.alibaba.fastjson.JSONObject;
import com.example.algorithm.domain.optMethods.GA.dao.SaveIRDao;
import com.example.algorithm.domain.optMethods.GA.entity.IRcontextResult;
import com.example.algorithm.domain.optMethods.GA.entity.SaveIRResult;
import org.springframework.amqp.rabbit.annotation.RabbitHandler;
import org.springframework.amqp.rabbit.annotation.RabbitListener;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import java.io.*;
import java.util.HashMap;
import java.util.Map;

@Component
@RabbitListener(queues = "topic.saveir")//监听的队列名称 topic.saveir
public class SaveIRReceiver {

    @Autowired
    SaveIRDao saveIrDao;
    @RabbitHandler
    public void process(String jsonString) throws IOException {
        IRcontextResult ircontextResult = JSONObject.parseObject(jsonString, IRcontextResult.class);
        String paths = ircontextResult.getAppdir()+ircontextResult.getPlatName()+"/"+ircontextResult.getAppName() + "/src_work/"+ircontextResult.getCompilerVersion()+"/llvm3.8.txt";
        Map<String,String> passestoHex = new HashMap<>();
        FileInputStream inputStream = new FileInputStream(paths);
        BufferedReader bufferedReader = new BufferedReader(new InputStreamReader(inputStream));
        String str = null;
        while ((str = bufferedReader.readLine()) != null) {
            String[] passestohex = str.split(" ");
            passestoHex.put(passestohex[1], passestohex[0]);
        }
        String IRname0 = ircontextResult.getIrName();
        String path = ircontextResult.getAppdir()+ircontextResult.getPlatName()+"/"+ircontextResult.getAppName() + "/src_work/"+ircontextResult.getCompilerVersion();
        File file = new File(path+"/"+IRname0);
        String IRname1 = "";
        for(int i = 0; i < ircontextResult.getSeqs().size(); i++)
        {
            if(passestoHex.get(ircontextResult.getSeqs().get(i)) == null)
            {
                continue;
            }
            else
            {

                IRname1 += passestoHex.get(ircontextResult.getSeqs().get(i));
            }

        }
        IRname1 += ".bc";
        if(rename(file,IRname1))
        {
            SaveIRResult saveIrResult = new SaveIRResult();
            saveIrResult.setAppName(ircontextResult.getAppName());
            saveIrResult.setCompilerVersion(ircontextResult.getCompilerVersion());
            saveIrResult.setIrName(IRname1);
            saveIrDao.addIRinfo(saveIrResult);
            System.out.println("第一个saveIRReceiver消费者收到消息  : " + saveIrResult.toString());

        }
        else{

            System.out.println("中间表示文件已存在！");

        }
    }

    public static boolean rename(final File file, final String newName) {
        // file is null then return false
        if (file == null)
        {
            return false;
        }
        // file doesn't exist then return false
        if (!file.exists())
        {
            return false;
        }

        // the new name is space then return false
        if (newName.equals(file.getName())) return true;
        File newFile = new File(file.getParent() + File.separator + newName);
        // the new name of file exists then return false
        return !newFile.exists()
                && file.renameTo(newFile);
    }


}
